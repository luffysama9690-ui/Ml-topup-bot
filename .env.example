# BotFather ဆီကရတဲ့ token ကို ဒီမှာထည့်ပါ
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin ရဲ့ Telegram user ID (order confirm/reject လုပ်ခွင့်ရှိမယ့်သူ)
# ID ရှာဖို့ @userinfobot ကို Telegram ထဲမှာ message ပို့ကြည့်ပါ
ADMIN_CHAT_ID=123456789

# Mini App ကို host လုပ်ထားတဲ့ public URL (https ဖြစ်ရမယ်, HTTP မရ)
# ဥပမာ - Render, Railway, Vercel, Fly.io စသဖြင့် deploy လုပ်ပြီးရတဲ့ URL
WEBAPP_URL=https://your-domain.example.com

# Server run မယ့် port
PORT=3000

# ငွေလွှဲမည့် အကောင့်အချက်အလက်များ
KBZPAY_NUMBER=09xxxxxxxxx
KBZPAY_NAME=Shop Owner Name
WAVEPAY_NUMBER=09xxxxxxxxx
WAVEPAY_NAME=Shop Owner Name
